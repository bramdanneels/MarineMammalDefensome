rule orthofinder_annot:
    input:
        orthogroups = rules.orthofinder.output.ortho_txt,
        eggnogAnnot = rules.eggnog.output.short_annot
    output:
        orthoannot = "results/orthology/all.ortho.annot",
        orthogroups = "results/orthology/all.ortho.groups"
    run:
        eggnogannot = {}
        for line in open(input.eggnogAnnot):
            gene, name = line.strip().split()
            eggnogannot[gene] = name
        orthodict = {}
        for line in open(input.orthogroups):
            OG, *genes = line.strip().split()
            OG = OG.rstrip(":")
            orthodict[OG] = orthodict.get(OG, [])
            orthodict[OG].extend(genes)
        OUT = open(output.orthoannot, "w+")
        OUTg = open(output.orthogroups, "w+")
        for ortho in sorted(orthodict.keys()):
            eggnognames = [eggnogannot.get(gene, "-") for gene in orthodict[ortho]]
            most_common_annot = max(set(eggnognames), key=eggnognames.count)
            if most_common_annot == "-" and len(set(eggnognames)) > 1:
                eggnognames = [name for name in eggnognames if name != "-" ]
                most_common_annot = max(set(eggnognames), key=eggnognames.count)
            print(ortho, most_common_annot, ",".join([eggnogannot.get(gene, "-") for gene in sorted(orthodict[ortho])]), sep="\t", file=OUT)
            print(ortho, *sorted(orthodict[ortho]), sep="\t", file=OUTg)
        OUT.close()
        OUTg.close()

checkpoint filter_ortho:
    input:
        annot = rules.orthofinder_annot.output.orthoannot,
        ogs = rules.orthofinder_annot.output.orthogroups
    output:
        filter_annot = "results/filtered/ortho.annot",
        filter_ogs = "results/filtered/ortho.groups"
    run:
        ogs = set()
        OUT = open(output.filter_annot, "w+")
        for line in open(input.annot):
            ortho, annot, annots = line.strip().split()
            if testAnnot(annot):
                ogs.add(ortho)
                print(line.strip(), file=OUT)
        OUT.close()        
        OUT = open(output.filter_ogs, "w+")
        for line in open(input.ogs):
            ortho, *genes = line.strip().split()
            if ortho in ogs:
                print(line.strip(), file=OUT)
        OUT.close()

