checkpoint get_aln_combo:
    input:
        ogs = rules.filter_ortho.output.filter_ogs,
        besthits = rules.diamond_besthit.output.besthits
    output:
        genes = "results/filtered/gene_aln.combo"
    run:
        besthits = {}
        for line in open(input.besthits):
            gene, hit, ratio, pid = line.strip().split()
            besthits[gene] = besthits.get(gene, [])
            besthits[gene].append((hit, ratio, pid))
        OUT = open(output.genes, "w+")
        for line in open(input.ogs):
            og, *genes = line.strip().split()
            for gene in genes:
                if gene in besthits.keys():
                    printhit = False
                    for hit, ratio, pid in besthits[gene]:
                        if hit in genes: 
                            print(gene, og, hit, ratio, pid, sep="\t", file=OUT)
                            printhit = True
                            break
                    if not printhit:
                        print(gene, og, "-", "-", "-", sep="\t", file=OUT)
                elif gene.split("_")[0] in genomes:
                    print(gene, og, "-", "-", "-", sep="\t", file=OUT)
        OUT.close()

rule getGeneLocations:
    input:
        gff = rules.get_longest_iso_gff.output.gff
    output:
        geneLoc = "results/pseudoAlignments/{genome}.genelocations"
    run:
        OUT = open(output.geneLoc, "w+")
        for line in open(input.gff):
            if not line.startswith("#"):
                chrom, source, feat, start, stop, dot, strand, sdot, info = line.strip().split("\t")
                if feat == "mRNA":
                    gene = info.split(";")[0].removeprefix("ID=")
                    print(gene, 
                      chrom, 
                      min(int(start), int(stop)), 
                      max(int(start), int(stop)),
                      sep="\t",
                      file=OUT)
        OUT.close()

rule extractGenomicRegion:
    input:
        genome = "genomes/{genome}"+genome_suffix,
        geneLoc = rules.getGeneLocations.output.geneLoc
    output:
        region = temporary("results/pseudoAlignments/{genome}/{gene}.fasta")
    params:
        padding = int(config["genePadding"])
    run:
        OUT = open(f"tempBED_{wildcards.genome}_{wildcards.gene}.bed", "w+")
        for line in open(input.geneLoc):
            if wildcards.gene in line:
                gene, contig, start, stop = line.strip().split("\t")
                print(f"{contig}\t{int(start)-params.padding}\t{int(stop)+params.padding}",
                file=OUT)
                break
        OUT.close()
        shell(f"seqtk subseq {input.genome} tempBED_{wildcards.genome}_{wildcards.gene}.bed > {output.region}")
        shell(f"rm tempBED_{wildcards.genome}_{wildcards.gene}.bed")

