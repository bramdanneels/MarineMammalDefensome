rule pseudo_info:
    input:
        get_defensome_alignments,
        ogs = rules.filter_ortho.output.filter_ogs,
        combos = rules.get_aln_combo.output.genes
    output:
        pseudo = "results/filtered/pseudostates.tbl"
    run:
        combos = {}
        for line in open(input.combos):
            gene, og, tophit, lratio, pid = line.strip().split()
            combos[(gene, og)] = [tophit, lratio, pid]
        OUT = open(output.pseudo, "w+")
        for line in open(input.ogs):
            og, *genes = line.strip().split()
            for gene in sorted(genes):
                if gene.split("_")[0] in genomes:
                    tophit, lratio, pid = combos[(gene, og)]
                    if tophit != "-":
                        if float(lratio) >= config["lengthCutoff"] and float(pid) >= config["percID_cutoff"]:
                            genome = gene.split("_")[0]
                            gw2 = checkPseudoGW(f"results/pseudoAlignments/{genome}/{gene}__{combos[(gene, og)][0]}.gw2")
                            if gw2 == False:
                                gw2 = 0
                            else:
                                gw2 = sum([int(x) for x in gw2])
                            exo = checkPseudoExo(f"results/pseudoAlignments/{genome}/{gene}__{combos[(gene, og)][0]}.exo")
                            if exo == False:
                                exo = 0
                            else:
                                exo = sum([int(x) for x in exo])
                            mnp = checkPseudoMP(f"results/pseudoAlignments/{genome}/{gene}__{combos[(gene, og)][0]}.mnp")
                            if mnp:
                                mnp = sum([int(x) for x in mnp])
                            else:
                                mnp = 0
                        if float(lratio) < config["lengthCutoff"]:
                            pseudo = "Pseudo"
                        elif float(pid) < config["percID_cutoff"]:
                            pseudo = "Pseudo"
                        elif [exo, gw2, mnp].count(0) <= 1:
                            pseudo = "Pseudo"
                        else:
                            pseudo = "Func"
                    else:
                        gw2 = "-"
                        exo = "-"
                        mnp = "-"
                        pseudo = "Func"
                    print(gene, og, pseudo, *combos[(gene, og)], gw2, exo, mnp, sep="\t", file=OUT)
        OUT.close()

rule og_summary:
    input:
        annot = rules.orthofinder_annot.output.orthoannot,
        ogs = rules.filter_ortho.output.filter_ogs,
        pseudo = rules.pseudo_info.output.pseudo,
    output:
        counts = "results/overview/genecounts.tbl"
    run:
        annotdict = {}
        for line in open(input.annot):
            og, annot, *annots = line.strip().split()
            annotdict[og] = annot
        pseudodict = {}
        for line in open(input.pseudo):
            gene, og, pseudo, *rest = line.strip().split()
            pseudodict[(gene, og)] = pseudo
        OUT = open(output.counts, "w+")
        print("Orthogroup", "Annot", *sorted(genomes), sep="\t", file=OUT)
        for line in open(input.ogs):
            og, *genes = line.strip().split()
            genomedict = {}
            for genome in genomes:
                genomedict[genome] = 0
            for gene in genes:
                if gene.split("_")[0] in genomes:
                    if pseudodict[(gene, og)] == "Func":
                        genome = gene.split("_")[0]
                        genomedict[genome] += 1
            print(og, annotdict[og], *[genomedict[genome] for genome in sorted(genomes)], sep="\t", file=OUT)
        OUT.close()

rule run_statistics:
    input:
        overview = rules.og_summary.output.counts
    output:
        stats = "results/overview/stats.tsv"
    params:
        genomeMap = config["genomeMap"]
    run:
        #Create dataframe
        genetable = pd.read_table(input.overview, header=0, index_col=0)
        genetableT = genetable.transpose().iloc[0:]
        species = pd.read_table(params.genomeMap, header=None, sep='\s+')
        validSpecies = species[species[0].isin(genetable.columns)]
        speciesDict = validSpecies.set_index(0).T.to_dict('index')[1]
        lineageDict = {}
        for species in sorted(speciesDict.keys()):
            lineage = speciesDict[species]
            lineageDict[lineage] = lineageDict.get(lineage, set())
            lineageDict[lineage].add(species)
        genetableT['lineage'] = pd.Series(speciesDict)
        #Initiate final dataframe
        comparisons = sorted(list(combinations(sorted(list(lineageDict.keys())), 2)))
        genes = genetableT.columns
        genes = genes.drop("lineage")
        final = pd.DataFrame(index=genes)
        final["Annot"] = genetable["Annot"]
        #Calculate counts/properties
        lineage_prop = {}
        lineage_mean = {}
        lineage_pres = {}
        lineage_abs = {}
        lineage_max = {}
        for lineage in lineageDict.keys():
            linmax = len(lineageDict[lineage])
            counts = genetableT[genetableT["lineage"] == lineage].drop("lineage", axis=1)
            lineage_prop[lineage] = round(((counts > 0).sum(axis=0)/linmax), 2)
            lineage_mean[lineage] = counts.mean(axis=0)
            lineage_pres[lineage] = (counts > 0).sum(axis=0)
            lineage_abs[lineage] = (counts == 0).sum(axis=0)
            lineage_max[lineage] = linmax
        for lineage in sorted(list(lineageDict.keys())):
            final[lineage+"_max"] = lineage_max[lineage]
            final[lineage+"_pres"] = lineage_pres[lineage]
            final[lineage+"_abs"] = lineage_abs[lineage]
            final[lineage+"_prop"] = lineage_prop[lineage]
            final[lineage+"_mean"] = [round(x, 2) for x in lineage_mean[lineage]]
        #Perform statistical tests
        for comp in comparisons:
            lin1, lin2 = comp
            lin1Tbl = genetableT[genetableT["lineage"] == lin1]
            lin2Tbl = genetableT[genetableT["lineage"] == lin2]
            fisherpdict = {}
            fisherpvalues = []
            mwupdict = {}
            mwupvalues = []
            for gene in genes:
                con_table = [[final.loc[gene][lin1+"_pres"], final.loc[gene][lin1+"_abs"]], [final.loc[gene][lin2+"_pres"], final.loc[gene][lin2+"_abs"]]]
                fisher = sp.stats.fisher_exact(con_table).pvalue
                fisherpdict[gene] = round(fisher, 5)
                fisherpvalues.append(fisher)
                mwu = sp.stats.mannwhitneyu(list(lin1Tbl[gene]), list(lin2Tbl[gene]), method="auto").pvalue
                mwupdict[gene] = round(mwu, 5)
                mwupvalues.append(mwu)
            fisheradjpvalues = [round(x, 5) for x in sp.stats.false_discovery_control(fisherpvalues)]
            mwuadjpvalues = [round(x, 5) for x in sp.stats.false_discovery_control(mwupvalues)]
            final["_".join(comp)+"_Fisherpval"] = pd.Series(fisherpdict)
            final["_".join(comp)+"_Fisheradjp"] = fisheradjpvalues
            final["_".join(comp)+"_MWUpval"] = pd.Series(mwupdict)
            final["_".join(comp)+"_MWUadjp"] = mwuadjpvalues
        #Print output    
        final.to_csv(output.stats, sep="\t")

