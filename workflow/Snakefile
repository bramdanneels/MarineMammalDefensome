#Preload genepatters for filtering
genes_any = config["genes_any"]
anygenes = set()
for line in open(genes_any, "r"):
    gene = line.strip()
    anygenes.add(gene.lower())
genes_letter = config["genes_letter"]
lettergenes = set()
for line in open(genes_letter, "r"):
    gene = line.strip()
    lettergenes.add(gene.lower())
genes_number = config["genes_number"]
numbergenes = set()
for line in open(genes_number, "r"):
    gene = line.strip()
    numbergenes.add(gene.lower())

def get_defensome_alignments(wildcards):
    ck_output = checkpoints.get_aln_combo.get(**wildcards).output[0]
    combos = set()
    for line in open(ck_output):
        gene, og, tophit, ratio, pid = line.strip().split()
        if tophit != "-":
            if float(ratio) >= config["lengthCutoff"] and float(pid) >= config["percID_cutoff"]:
                genome = gene.split("_")[0]
                combos.add(f"{genome}/{gene}__{tophit}")
    gene_alignments = expand("results/pseudoAlignments/{combo}.{method}", combo=sorted(list(combos)), method=["gw2", "exo", "mnp"])
    return(gene_alignments)

def checkPseudoMP(MPoutput):
    for line in open(MPoutput):
        if not line[:5] in ["##ATA", "##AAS", "##AQA"]:
            aln = line.strip().split()
            fs = aln[15].split(":")[-1]
            st = aln[16].split(":")[-1]
            return(st, fs)
    return(False)

def checkPseudoExo(exonerateoutput):
    with open(exonerateoutput, "r") as file:
        filecontent = file.read()
    alignments = filecontent.split("C4 Alignment:\n")[1:]
    bestscore = 0
    best_alignment = False
    for alignment in alignments:
        for line in alignment.split("\n"):
            if "Raw score:" in line:
                score = int(line.strip().split()[2])
                if score > bestscore:
                    bestscore = score
                    best_alignment = alignment
                break
    if best_alignment:
        protseq = ""
        inserts = 0
        deletions = 0
        sugar = False
        for number, line in enumerate(best_alignment.split("\n")):
            if "sugar:" in line:
                sugar=True
            if number-5 > 0 and number%5 == 0 and not sugar:
                protseq += line.strip()
        protseq = protseq.strip().rstrip("***").replace(" ", "").replace("+", "").replace("{", "").replace("}", "").replace("-", "").replace("##", "#")
        stop = protseq.count("***")
        protseq = "".join([c for c, _ in groupby(protseq)])
        shift = protseq.count("#")
        return(str(stop), str(shift))
    else:
        return(False)

def checkPseudoGW(genewiseoutput):
    with open(genewiseoutput, "r") as file:
        filecontent = file.read()
    alignments = filecontent.strip().split("genewise output\n")
    bestscore = 0
    best_alignment = False
    for alignment in alignments:
        for line in alignment.split("\n"):
            if "Score" in line and "over entire alignment" in line:
                score = float(line.lstrip("Score ").rstrip(" bits over entire alignment\n"))
                if score > bestscore:
                    bestscore = score
                    best_alignment = alignment
                break
    if best_alignment:
        protseq = ""
        seqend = False
        for number, line in enumerate(best_alignment.split("\n")):
            if "//" in line:
                seqend = True
                break
            if number > 0 and number%8 == 0 and not seqend:
                protseq += line.strip()
        table = str.maketrans('', '', string.ascii_lowercase)
        protseq = protseq.translate(table).replace(" ", "").replace("-:-", "").replace("[", "").replace("]", "").replace(":-", "").replace("-:", "").replace(":", "")
        stop = protseq.count("X")
        shift = protseq.count("!")
        return(str(stop), str(shift))
    else:
        return(False)

def testAnnot(name):
    for pattern in anygenes:
        if name.startswith(pattern):
            return(True)
    for pattern in lettergenes:
        if name.startswith(pattern):
            if name.removeprefix(pattern):
                next_char = name.removeprefix(pattern)[0]
                if not next_char.isdigit():
                    return(True)
            else:
                return(True)
    for pattern in numbergenes:
        if name.startswith(pattern):
            if name.removeprefix(pattern):
                next_char = name.removeprefix(pattern)[0]
            else:
                next_char = "1"
            if next_char.isdigit():
                return(True)
    return(False)

def genomeinput(genome_suffix):
    if genome_suffix.endswith(".gz"):
        return("results/annotation/{genome}.genome.fasta")
    else:
        return("genomes/{genome}"+genome_suffix)

